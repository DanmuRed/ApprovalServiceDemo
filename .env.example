# BE API base URL
REACT_APP_API_BASE=http://localhost:8080

# 결재선 미리보기 iframe 의 출처 URL (fe/ 빌더 서비스).
# 신청 탭에서 "미리보기" 클릭 시 이 origin 의 /playbooks/{id}/preview 를 iframe 으로 띄운다.
REACT_APP_FE_BASE=http://localhost:3000

# 관리자 콘솔 → 설정 → 인증 → API 토큰 에서 발급한 JWT 평문.
# BE 가 app.auth.jwt.enforce=true 로 운영되면 필수.
REACT_APP_API_TOKEN=

# 결재 도메인 회사 코드. 플레이북 / 결재 모두 이 값으로 묶인다.
REACT_APP_COMPANY_CODE=DEFAULT
